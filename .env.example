# Frontend (Cloudflare Pages)
VITE_API_URL=http://localhost:8787
VITE_RECAPTCHA_SITE_KEY=replace_with_recaptcha_v3_site_key

# Backend (Render)
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173,https://guifer.tech,https://www.guifer.tech
CLIENT_IP_SOURCE=direct
KEEP_ALIVE_SECRET=replace_with_at_least_32_random_characters

# Supabase (server only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me

# Brevo SMTP: Render Free blocks 25, 465 and 587; use Brevo's port 2525
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=2525
BREVO_SMTP_USER=your_brevo_smtp_login
BREVO_SMTP_KEY=replace_with_your_brevo_smtp_key

# CONTACT_EMAIL_FROM must belong to a sender/domain authenticated in Brevo
CONTACT_EMAIL_FROM="Guilherme <contato@guifer.tech>"
CONTACT_EMAIL_TO=contato@guifer.tech

# Google reCAPTCHA v3 (server only)
RECAPTCHA_SECRET_KEY=replace_with_recaptcha_v3_secret_key
# Temporary during annual rotation only; remove after the new key is validated
RECAPTCHA_SECRET_KEY_PREVIOUS=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ALLOWED_HOSTNAMES=localhost,guifer.tech

# Contact endpoint
CONTACT_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4173,https://guifer.tech,https://www.guifer.tech
CONTACT_RATE_LIMIT_SECRET=replace_with_at_least_32_random_characters
CONTACT_RATE_LIMIT_WINDOW_SECONDS=900
CONTACT_RATE_LIMIT_IP_MAX=5
CONTACT_RATE_LIMIT_GLOBAL_MAX=100

# Coffee interaction rate limit (server only)
COFFEE_RATE_LIMIT_SECRET=replace_with_at_least_32_random_characters

# GitHub fine-grained PAT: personal owner, public repositories read-only, annual expiration
GITHUB_TOKEN=replace_with_an_annual_fine_grained_pat

# GitHub Actions repository variable (not used by the application process)
KEEP_ALIVE_API_URL=https://your-render-service.onrender.com
